    { "type": "basic", "front": { "text": "bring up", "hint": "phrasal verb" }, "back": { "text": "mencionar / criar (filho)", "examples": [{ "en": "She brought up an interesting point.", "pt": "Ela trouxe um ponto interessante." }, { "en": "He was brought up in Brazil.", "pt": "Ele foi criado no Brasil." }] }, "tags": ["phrasal-verb", "b1"] },
    { "type": "basic", "front": { "text": "get over", "hint": "phrasal verb" }, "back": { "text": "superar (algo difícil)", "examples": [{ "en": "It took him years to get over the loss.", "pt": "Levou anos para ele superar a perda." }] }, "tags": ["phrasal-verb", "b1"] },
