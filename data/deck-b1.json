    { "type": "basic", "front": { "text": "although" }, "back": { "text": "embora, apesar de que", "examples": [{ "en": "Although it was raining, we went out.", "pt": "Embora estivesse chovendo, saímos." }] }, "tags": ["conjunction", "b1"] },
