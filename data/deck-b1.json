    { "type": "basic", "front": { "text": "lose weight", "hint": "collocation" }, "back": { "text": "perder peso", "examples": [{ "en": "I want to lose weight.", "pt": "Quero perder peso." }] }, "tags": ["collocation", "b1"] },
