    { "type": "basic", "front": { "text": "particular" }, "back": { "text": "particular, específico", "examples": [{ "en": "Any particular reason?", "pt": "Alguma razão específica?" }] }, "tags": ["adj", "b1"] },
    { "type": "basic", "front": { "text": "available" }, "back": { "text": "disponível", "examples": [{ "en": "Is the room available?", "pt": "O quarto está disponível?" }] }, "tags": ["adj", "b1"] },
    { "type": "basic", "front": { "text": "consider" }, "back": { "text": "considerar, pensar sobre", "examples": [{ "en": "I'll consider your offer.", "pt": "Vou considerar sua oferta." }] }, "tags": ["verb", "b1"] },
    { "type": "basic", "front": { "text": "achieve" }, "back": { "text": "alcançar, conquistar", "examples": [{ "en": "She achieved her goals.", "pt": "Ela alcançou seus objetivos." }] }, "tags": ["verb", "b1"] },
