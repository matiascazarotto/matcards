    { "type": "basic", "front": { "text": "turn down", "hint": "phrasal verb" }, "back": { "text": "recusar / abaixar volume", "examples": [{ "en": "She turned down the job offer.", "pt": "Ela recusou a oferta." }, { "en": "Turn down the music.", "pt": "Abaixe a música." }] }, "tags": ["phrasal-verb", "b1"] },
