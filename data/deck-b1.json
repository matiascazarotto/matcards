    { "type": "basic", "front": { "text": "look after", "hint": "phrasal verb" }, "back": { "text": "cuidar de (alguém ou algo)", "examples": [{ "en": "She looks after her grandmother.", "pt": "Ela cuida da avó." }] }, "tags": ["phrasal-verb", "b1"] },
    { "type": "basic", "front": { "text": "get along (with)", "hint": "phrasal verb" }, "back": { "text": "se dar bem (com alguém)", "examples": [{ "en": "I get along well with my boss.", "pt": "Me dou bem com meu chefe." }] }, "tags": ["phrasal-verb", "b1"] },
