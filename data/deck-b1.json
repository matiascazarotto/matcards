    { "type": "basic", "front": { "text": "make a decision", "hint": "collocation" }, "back": { "text": "tomar uma decisão", "examples": [{ "en": "It's hard to make a decision now.", "pt": "É difícil tomar uma decisão agora." }] }, "tags": ["collocation", "b1"] },
