    { "type": "basic", "front": { "text": "make friends", "hint": "collocation" }, "back": { "text": "fazer amigos", "examples": [{ "en": "He makes friends easily.", "pt": "Ele faz amigos com facilidade." }] }, "tags": ["collocation", "b1"] },
