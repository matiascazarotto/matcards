    { "type": "basic", "front": { "text": "involve" }, "back": { "text": "envolver, incluir", "examples": [{ "en": "The job involves traveling.", "pt": "O trabalho envolve viagens." }] }, "tags": ["verb", "b1"] },
    { "type": "basic", "front": { "text": "suggest" }, "back": { "text": "sugerir", "examples": [{ "en": "I suggest we leave now.", "pt": "Sugiro que saiamos agora." }] }, "tags": ["verb", "b1"] },
    { "type": "basic", "front": { "text": "require" }, "back": { "text": "exigir, requerer", "examples": [{ "en": "This job requires experience.", "pt": "Este trabalho exige experiência." }] }, "tags": ["verb", "b1"] },

    { "type": "cloze", "front": { "hint": "present perfect" }, "cloze": { "sentence": "I [have lived] here for ten years.", "blank": "have lived" }, "back": { "text": "Present perfect (have/has + particípio) para ações que começaram no passado e continuam até agora" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "first conditional" }, "cloze": { "sentence": "If it rains, I [will stay] home.", "blank": "will stay" }, "back": { "text": "First conditional: if + present simple, ... will + verb (situações reais/prováveis no futuro)" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "second conditional" }, "cloze": { "sentence": "If I [had] more time, I would learn piano.", "blank": "had" }, "back": { "text": "Second conditional: if + past simple, ... would + verb (situações irreais/hipotéticas)" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "modal verb" }, "cloze": { "sentence": "You [should] see a doctor.", "blank": "should" }, "back": { "text": "'should' = sugestão ou recomendação" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "used to" }, "cloze": { "sentence": "I [used to] play tennis when I was young.", "blank": "used to" }, "back": { "text": "'used to + verb' = costumava (hábito no passado que não acontece mais)" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "ago vs for vs since" }, "cloze": { "sentence": "I haven't seen her [since] 2020.", "blank": "since" }, "back": { "text": "'since' + ponto no tempo (since Monday, since 2020). 'for' + duração (for 5 years)" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "passive voice" }, "cloze": { "sentence": "The book [was written] by Tolkien.", "blank": "was written" }, "back": { "text": "Voz passiva: to be + particípio. Foca em quem/o que recebe a ação" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "reported speech" }, "cloze": { "sentence": "She said she [was] tired.", "blank": "was" }, "back": { "text": "Discurso indireto: presente vira passado (am/is → was, are → were, will → would)" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "comparative" }, "cloze": { "sentence": "This is [more interesting] than the last one.", "blank": "more interesting" }, "back": { "text": "Adjetivos longos: 'more + adjective + than'. Adjetivos curtos: 'adjective + -er + than'" }, "tags": ["grammar", "b1"] },
    { "type": "cloze", "front": { "hint": "relative clause" }, "cloze": { "sentence": "The man [who] called me is my uncle.", "blank": "who" }, "back": { "text": "Pronomes relativos: who (pessoas), which (coisas), that (ambos)" }, "tags": ["grammar", "b1"] },

    { "type": "listening", "front": { "text": "Could you please repeat that?", "audioText": "Could you please repeat that?" }, "back": { "text": "Você poderia repetir, por favor?" }, "tags": ["listening", "phrase", "b1"] },
    { "type": "listening", "front": { "text": "How long have you been studying English?", "audioText": "How long have you been studying English?" }, "back": { "text": "Há quanto tempo você estuda inglês?" }, "tags": ["listening", "phrase", "b1"] }
  ]
}
