    { "type": "basic", "front": { "text": "take a look", "hint": "collocation" }, "back": { "text": "dar uma olhada", "examples": [{ "en": "Take a look at this report.", "pt": "Dá uma olhada neste relatório." }] }, "tags": ["collocation", "b1"] },
    { "type": "basic", "front": { "text": "make progress", "hint": "collocation" }, "back": { "text": "fazer progresso", "examples": [{ "en": "She's making good progress.", "pt": "Ela está fazendo bom progresso." }] }, "tags": ["collocation", "b1"] },
    { "type": "basic", "front": { "text": "do research", "hint": "collocation" }, "back": { "text": "fazer pesquisa", "examples": [{ "en": "He does research on AI.", "pt": "Ele faz pesquisa em IA." }] }, "tags": ["collocation", "b1"] },
