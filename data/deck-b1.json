    { "type": "basic", "front": { "text": "put up with", "hint": "phrasal verb" }, "back": { "text": "tolerar, aguentar", "examples": [{ "en": "I can't put up with this noise.", "pt": "Não aguento este barulho." }] }, "tags": ["phrasal-verb", "b1"] },
