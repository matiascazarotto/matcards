    { "type": "basic", "front": { "text": "run out (of)", "hint": "phrasal verb" }, "back": { "text": "ficar sem (alguma coisa)", "examples": [{ "en": "We ran out of milk.", "pt": "Ficamos sem leite." }] }, "tags": ["phrasal-verb", "b1"] },
    { "type": "basic", "front": { "text": "carry on", "hint": "phrasal verb" }, "back": { "text": "continuar (fazendo algo)", "examples": [{ "en": "Just carry on with your work.", "pt": "Apenas continue seu trabalho." }] }, "tags": ["phrasal-verb", "b1"] },
    { "type": "basic", "front": { "text": "find out", "hint": "phrasal verb" }, "back": { "text": "descobrir (informação)", "examples": [{ "en": "I found out the truth.", "pt": "Descobri a verdade." }] }, "tags": ["phrasal-verb", "b1"] },
