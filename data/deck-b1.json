    { "type": "basic", "front": { "text": "show up", "hint": "phrasal verb" }, "back": { "text": "aparecer (em algum lugar)", "examples": [{ "en": "He didn't show up to the meeting.", "pt": "Ele não apareceu na reunião." }] }, "tags": ["phrasal-verb", "b1"] },
