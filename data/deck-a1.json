{
  "id": "deck-a1-builtin",
  "name": "A1 — Fundação absoluta",
  "level": "a1",
  "description": "Pronouns, articles, prepositions, question words, números, família, cores, partes do corpo e verbos básicos não cobertos pelo deck A2. Para começar do zero absoluto.",
  "cards": [
    { "type": "basic", "front": { "text": "I" }, "back": { "text": "eu (pronome de 1ª pessoa, SEMPRE maiúsculo em inglês)", "examples": [{ "en": "I am a student.", "pt": "Eu sou estudante." }, { "en": "I like coffee.", "pt": "Eu gosto de café." }] }, "tags": ["pronoun", "a1"] },
    { "type": "basic", "front": { "text": "you" }, "back": { "text": "você / vocês (mesma forma pra singular e plural)", "examples": [{ "en": "You are my friend.", "pt": "Você é meu amigo." }, { "en": "Are you ready?", "pt": "Você está pronto?" }] }, "tags": ["pronoun", "a1"] },
    { "type": "basic", "front": { "text": "he" }, "back": { "text": "ele (para pessoas masculinas)", "examples": [{ "en": "He is my brother.", "pt": "Ele é meu irmão." }, { "en": "He works in a bank.", "pt": "Ele trabalha em um banco." }] }, "tags": ["pronoun", "a1"] },
    { "type": "basic", "front": { "text": "she" }, "back": { "text": "ela (para pessoas femininas)", "examples": [{ "en": "She is a doctor.", "pt": "Ela é médica." }, { "en": "She likes music.", "pt": "Ela gosta de música." }] }, "tags": ["pronoun", "a1"] },
    { "type": "basic", "front": { "text": "it" }, "back": { "text": "ele/ela para objetos/animais/situações (PT não tem direto — em inglês é obrigatório)", "examples": [{ "en": "It's a book.", "pt": "É um livro." }, { "en": "It's raining.", "pt": "Está chovendo." }] }, "tags": ["pronoun", "a1"] },
    { "type": "basic", "front": { "text": "we" }, "back": { "text": "nós / a gente", "examples": [{ "en": "We are happy.", "pt": "Nós estamos felizes." }, { "en": "We live in Brazil.", "pt": "A gente mora no Brasil." }] }, "tags": ["pronoun", "a1"] },
    { "type": "basic", "front": { "text": "they" }, "back": { "text": "eles / elas (sem distinção de gênero)", "examples": [{ "en": "They are my parents.", "pt": "Eles são meus pais." }, { "en": "They speak Spanish.", "pt": "Eles falam espanhol." }] }, "tags": ["pronoun", "a1"] },
    { "type": "basic", "front": { "text": "my" }, "back": { "text": "meu, minha, meus, minhas (possessivo de I)", "examples": [{ "en": "This is my house.", "pt": "Esta é minha casa." }, { "en": "My name is John.", "pt": "Meu nome é João." }] }, "tags": ["possessive", "a1"] },
    { "type": "basic", "front": { "text": "your" }, "back": { "text": "seu, sua, seus, suas (possessivo de you)", "examples": [{ "en": "What's your name?", "pt": "Qual é o seu nome?" }, { "en": "Is this your bag?", "pt": "Essa é a sua bolsa?" }] }, "tags": ["possessive", "a1"] },
    { "type": "basic", "front": { "text": "his" }, "back": { "text": "dele (possessivo de he)", "examples": [{ "en": "His car is red.", "pt": "O carro dele é vermelho." }, { "en": "I met his sister.", "pt": "Conheci a irmã dele." }] }, "tags": ["possessive", "a1"] },
    { "type": "basic", "front": { "text": "her" }, "back": { "text": "dela (possessivo de she) OU 'a ela' (objeto)", "examples": [{ "en": "Her house is big.", "pt": "A casa dela é grande." }, { "en": "I called her yesterday.", "pt": "Liguei pra ela ontem." }] }, "tags": ["possessive", "pronoun", "a1"] },
    { "type": "basic", "front": { "text": "our" }, "back": { "text": "nosso, nossa, nossos, nossas (possessivo de we)", "examples": [{ "en": "Our team won.", "pt": "Nosso time ganhou." }, { "en": "This is our dog.", "pt": "Este é nosso cachorro." }] }, "tags": ["possessive", "a1"] },
    { "type": "basic", "front": { "text": "their" }, "back": { "text": "deles, delas (possessivo de they). NÃO confundir com 'there' (lá).", "examples": [{ "en": "Their kids are at school.", "pt": "Os filhos deles estão na escola." }, { "en": "I like their music.", "pt": "Gosto da música deles." }] }, "tags": ["possessive", "a1"] },
    { "type": "basic", "front": { "text": "a / an" }, "back": { "text": "um, uma (artigo indefinido). 'an' antes de som de vogal: an apple, an hour. 'a' antes de consoante: a book.", "examples": [{ "en": "I have a dog.", "pt": "Eu tenho um cachorro." }, { "en": "She's an engineer.", "pt": "Ela é engenheira." }] }, "tags": ["article", "a1"] },
    { "type": "basic", "front": { "text": "the" }, "back": { "text": "o, a, os, as (artigo definido — uma única forma pra todos gêneros e números). Pronuncia-se 'thuh' antes de consoante, 'thee' antes de vogal.", "examples": [{ "en": "The book is on the table.", "pt": "O livro está na mesa." }, { "en": "Open the door.", "pt": "Abra a porta." }] }, "tags": ["article", "a1"] },
    { "type": "basic", "front": { "text": "what" }, "back": { "text": "o que, qual (pergunta sobre coisa/conceito)", "examples": [{ "en": "What is this?", "pt": "O que é isso?" }, { "en": "What's your job?", "pt": "Qual é o seu trabalho?" }] }, "tags": ["question", "a1"] },
    { "type": "basic", "front": { "text": "who" }, "back": { "text": "quem (pergunta sobre pessoa)", "examples": [{ "en": "Who is she?", "pt": "Quem é ela?" }, { "en": "Who called?", "pt": "Quem ligou?" }] }, "tags": ["question", "a1"] },
    { "type": "basic", "front": { "text": "where" }, "back": { "text": "onde (pergunta sobre lugar). NÃO confundir com 'were' (passado de 'are').", "examples": [{ "en": "Where do you live?", "pt": "Onde você mora?" }, { "en": "Where is the bathroom?", "pt": "Onde fica o banheiro?" }] }, "tags": ["question", "a1"] },
    { "type": "basic", "front": { "text": "when" }, "back": { "text": "quando (pergunta sobre tempo)", "examples": [{ "en": "When is your birthday?", "pt": "Quando é seu aniversário?" }, { "en": "When do we start?", "pt": "Quando começamos?" }] }, "tags": ["question", "a1"] },
    { "type": "basic", "front": { "text": "why" }, "back": { "text": "por que (pergunta sobre razão). Resposta: 'because' (porque).", "examples": [{ "en": "Why are you sad?", "pt": "Por que você está triste?" }, { "en": "Why is it closed?", "pt": "Por que está fechado?" }] }, "tags": ["question", "a1"] },
    { "type": "basic", "front": { "text": "how" }, "back": { "text": "como (pergunta sobre modo). Combina: how much (quanto), how many (quantos), how old (quantos anos).", "examples": [{ "en": "How are you?", "pt": "Como você está?" }, { "en": "How much is this?", "pt": "Quanto custa isso?" }] }, "tags": ["question", "a1"] },
    { "type": "basic", "front": { "text": "in" }, "back": { "text": "em, dentro de (cidade, país, mês, ano). 'in Brazil', 'in 2026', 'in January'.", "examples": [{ "en": "I live in São Paulo.", "pt": "Moro em São Paulo." }, { "en": "It's in the box.", "pt": "Está dentro da caixa." }] }, "tags": ["preposition", "a1"] },
    { "type": "basic", "front": { "text": "on" }, "back": { "text": "em, sobre (superfície ou dia específico). 'on the table', 'on Monday'.", "examples": [{ "en": "The keys are on the table.", "pt": "As chaves estão em cima da mesa." }, { "en": "I work on Mondays.", "pt": "Trabalho nas segundas." }] }, "tags": ["preposition", "a1"] },
    { "type": "basic", "front": { "text": "at" }, "back": { "text": "em (ponto específico, hora). 'at home', 'at 3pm', 'at school'.", "examples": [{ "en": "She's at work.", "pt": "Ela está no trabalho." }, { "en": "Meet me at 8.", "pt": "Me encontre às 8." }] }, "tags": ["preposition", "a1"] },
    { "type": "basic", "front": { "text": "to" }, "back": { "text": "para, a (movimento/direção). 'go to the store', 'give to me'.", "examples": [{ "en": "I'm going to the park.", "pt": "Vou ao parque." }, { "en": "Give this to him.", "pt": "Dê isso pra ele." }] }, "tags": ["preposition", "a1"] },
    { "type": "basic", "front": { "text": "from" }, "back": { "text": "de, vindo de (origem). 'from Brazil', 'from school'.", "examples": [{ "en": "I'm from Brazil.", "pt": "Eu sou do Brasil." }, { "en": "She came from work.", "pt": "Ela veio do trabalho." }] }, "tags": ["preposition", "a1"] },
    { "type": "basic", "front": { "text": "with" }, "back": { "text": "com (companhia ou instrumento)", "examples": [{ "en": "Come with me.", "pt": "Vem comigo." }, { "en": "I write with a pen.", "pt": "Eu escrevo com caneta." }] }, "tags": ["preposition", "a1"] },
    { "type": "basic", "front": { "text": "for" }, "back": { "text": "para, por (destinatário, propósito, duração). 'for you', 'for work', 'for 3 hours'.", "examples": [{ "en": "This is for you.", "pt": "Isso é pra você." }, { "en": "I waited for an hour.", "pt": "Esperei por uma hora." }] }, "tags": ["preposition", "a1"] },
    { "type": "basic", "front": { "text": "one, two, three" }, "back": { "text": "um, dois, três. Sequência completa 1-10: one, two, three, four, five, six, seven, eight, nine, ten.", "examples": [{ "en": "I have two cats.", "pt": "Eu tenho dois gatos." }, { "en": "Count to ten.", "pt": "Conte até dez." }] }, "tags": ["number", "a1"] },
    { "type": "basic", "front": { "text": "ten, twenty, thirty" }, "back": { "text": "dez, vinte, trinta. Sequência 10-100: ten, twenty, thirty, forty, fifty, sixty, seventy, eighty, ninety, one hundred.", "examples": [{ "en": "She's thirty years old.", "pt": "Ela tem trinta anos." }, { "en": "There were fifty people.", "pt": "Tinha cinquenta pessoas." }] }, "tags": ["number", "a1"] },
    { "type": "basic", "front": { "text": "hundred / thousand / million" }, "back": { "text": "cem / mil / milhão. CUIDADO: em inglês usa-se 'and' entre centena e dezena: 'one hundred and twenty' (cento e vinte).", "examples": [{ "en": "It costs five hundred dollars.", "pt": "Custa quinhentos dólares." }, { "en": "There are a thousand people.", "pt": "Tem mil pessoas." }] }, "tags": ["number", "a1"] },
    { "type": "basic", "front": { "text": "mother" }, "back": { "text": "mãe. Informal: mom (US), mum (UK). Reforço: NÃO 'parents' (que é pais — pai+mãe).", "examples": [{ "en": "My mother lives in Rio.", "pt": "Minha mãe mora no Rio." }, { "en": "Mom, can you help me?", "pt": "Mãe, pode me ajudar?" }] }, "tags": ["family", "a1"] },
    { "type": "basic", "front": { "text": "father" }, "back": { "text": "pai. Informal: dad.", "examples": [{ "en": "My father is a teacher.", "pt": "Meu pai é professor." }, { "en": "Dad, where are my keys?", "pt": "Pai, onde estão minhas chaves?" }] }, "tags": ["family", "a1"] },
    { "type": "basic", "front": { "text": "brother" }, "back": { "text": "irmão. Plural: brothers.", "examples": [{ "en": "I have two brothers.", "pt": "Tenho dois irmãos." }, { "en": "My brother is younger.", "pt": "Meu irmão é mais novo." }] }, "tags": ["family", "a1"] },
    { "type": "basic", "front": { "text": "sister" }, "back": { "text": "irmã.", "examples": [{ "en": "She's my sister.", "pt": "Ela é minha irmã." }, { "en": "My sister lives abroad.", "pt": "Minha irmã mora fora." }] }, "tags": ["family", "a1"] },
    { "type": "basic", "front": { "text": "son / daughter" }, "back": { "text": "filho / filha. Filhos (em geral) = children ou kids.", "examples": [{ "en": "We have a son and a daughter.", "pt": "Temos um filho e uma filha." }, { "en": "My kids are at school.", "pt": "Meus filhos estão na escola." }] }, "tags": ["family", "a1"] },
    { "type": "basic", "front": { "text": "husband / wife" }, "back": { "text": "marido / esposa. Plural de wife: wives.", "examples": [{ "en": "Her husband is a chef.", "pt": "O marido dela é chef." }, { "en": "My wife works from home.", "pt": "Minha esposa trabalha de casa." }] }, "tags": ["family", "a1"] },
    { "type": "basic", "front": { "text": "red / blue / green" }, "back": { "text": "vermelho / azul / verde. Cores não variam em gênero/número em inglês: 'red cars', 'red car'.", "examples": [{ "en": "I have a red car.", "pt": "Tenho um carro vermelho." }, { "en": "The sky is blue.", "pt": "O céu é azul." }] }, "tags": ["color", "a1"] },
    { "type": "basic", "front": { "text": "black / white" }, "back": { "text": "preto / branco.", "examples": [{ "en": "She wears black clothes.", "pt": "Ela usa roupa preta." }, { "en": "The wall is white.", "pt": "A parede é branca." }] }, "tags": ["color", "a1"] },
    { "type": "basic", "front": { "text": "yellow / orange / pink" }, "back": { "text": "amarelo / laranja / rosa.", "examples": [{ "en": "The sun is yellow.", "pt": "O sol é amarelo." }, { "en": "She has a pink dress.", "pt": "Ela tem um vestido rosa." }] }, "tags": ["color", "a1"] },
    { "type": "basic", "front": { "text": "Monday, Tuesday, Wednesday" }, "back": { "text": "Segunda, terça, quarta. Dias da semana SEMPRE maiúsculos em inglês. Sequência: Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Sunday.", "examples": [{ "en": "I work from Monday to Friday.", "pt": "Trabalho de segunda à sexta." }, { "en": "See you on Wednesday.", "pt": "Te vejo quarta." }] }, "tags": ["time", "a1"] },
    { "type": "basic", "front": { "text": "weekend" }, "back": { "text": "fim de semana (sábado + domingo). 'On the weekend' (US) ou 'at the weekend' (UK).", "examples": [{ "en": "Have a good weekend!", "pt": "Bom fim de semana!" }, { "en": "What did you do on the weekend?", "pt": "O que você fez no fim de semana?" }] }, "tags": ["time", "a1"] },
    { "type": "basic", "front": { "text": "January, February, March" }, "back": { "text": "Janeiro, fevereiro, março. Meses SEMPRE maiúsculos. Sequência completa: January, February, March, April, May, June, July, August, September, October, November, December.", "examples": [{ "en": "My birthday is in March.", "pt": "Meu aniversário é em março." }, { "en": "We met in January.", "pt": "A gente se conheceu em janeiro." }] }, "tags": ["time", "a1"] },
    { "type": "basic", "front": { "text": "now" }, "back": { "text": "agora. Frequentemente combinado: right now (agora mesmo), for now (por enquanto).", "examples": [{ "en": "I'm busy now.", "pt": "Estou ocupado agora." }, { "en": "Call me right now.", "pt": "Me liga agora mesmo." }] }, "tags": ["time", "a1"] },
    { "type": "basic", "front": { "text": "today" }, "back": { "text": "hoje.", "examples": [{ "en": "Today is Friday.", "pt": "Hoje é sexta." }, { "en": "I don't work today.", "pt": "Não trabalho hoje." }] }, "tags": ["time", "a1"] },
    { "type": "basic", "front": { "text": "tomorrow" }, "back": { "text": "amanhã. 'The day after tomorrow' = depois de amanhã.", "examples": [{ "en": "See you tomorrow.", "pt": "Te vejo amanhã." }, { "en": "Tomorrow is my birthday.", "pt": "Amanhã é meu aniversário." }] }, "tags": ["time", "a1"] },
    { "type": "basic", "front": { "text": "yesterday" }, "back": { "text": "ontem. 'The day before yesterday' = anteontem.", "examples": [{ "en": "I called you yesterday.", "pt": "Te liguei ontem." }, { "en": "Yesterday was sunny.", "pt": "Ontem fez sol." }] }, "tags": ["time", "a1"] },
    { "type": "basic", "front": { "text": "always / usually / sometimes / never" }, "back": { "text": "sempre / geralmente / às vezes / nunca. Frequência. Em afirmativa: vão antes do verbo principal ('I always work').", "examples": [{ "en": "She always arrives early.", "pt": "Ela sempre chega cedo." }, { "en": "I sometimes drink coffee.", "pt": "Às vezes tomo café." }] }, "tags": ["adverb", "a1"] },
    { "type": "basic", "front": { "text": "eye / mouth / nose / ear" }, "back": { "text": "olho / boca / nariz / orelha. Plural: eyes, mouths, noses, ears.", "examples": [{ "en": "She has blue eyes.", "pt": "Ela tem olhos azuis." }, { "en": "Open your mouth.", "pt": "Abra a boca." }] }, "tags": ["body", "a1"] },
    { "type": "basic", "front": { "text": "hand / arm / leg / foot" }, "back": { "text": "mão / braço / perna / pé. Plural de foot: feet (irregular).", "examples": [{ "en": "Give me your hand.", "pt": "Me dá sua mão." }, { "en": "My feet hurt.", "pt": "Meus pés doem." }] }, "tags": ["body", "a1"] },
    { "type": "basic", "front": { "text": "head / hair" }, "back": { "text": "cabeça / cabelo. 'Hair' geralmente uncountable (sem plural).", "examples": [{ "en": "I have a headache.", "pt": "Estou com dor de cabeça." }, { "en": "She has long hair.", "pt": "Ela tem cabelo longo." }] }, "tags": ["body", "a1"] },
    { "type": "basic", "front": { "text": "to eat" }, "back": { "text": "comer — eat, ate, eaten (irregular).", "examples": [{ "en": "I eat breakfast at 7.", "pt": "Como o café às 7." }, { "en": "She ate pizza yesterday.", "pt": "Ela comeu pizza ontem." }] }, "tags": ["verb", "irregular", "a1"] },
    { "type": "basic", "front": { "text": "to drink" }, "back": { "text": "beber — drink, drank, drunk (irregular). Cuidado: 'drunk' como adjetivo = bêbado.", "examples": [{ "en": "I drink water every day.", "pt": "Bebo água todo dia." }, { "en": "He drank too much.", "pt": "Ele bebeu demais." }] }, "tags": ["verb", "irregular", "a1"] },
    { "type": "basic", "front": { "text": "to sleep" }, "back": { "text": "dormir — sleep, slept, slept (irregular).", "examples": [{ "en": "I sleep 8 hours.", "pt": "Durmo 8 horas." }, { "en": "She slept on the couch.", "pt": "Ela dormiu no sofá." }] }, "tags": ["verb", "irregular", "a1"] },
    { "type": "basic", "front": { "text": "to walk" }, "back": { "text": "andar, caminhar — walk, walked (regular).", "examples": [{ "en": "I walk to work.", "pt": "Vou andando pro trabalho." }, { "en": "Let's walk in the park.", "pt": "Vamos caminhar no parque." }] }, "tags": ["verb", "regular", "a1"] },
    { "type": "basic", "front": { "text": "to read / to write" }, "back": { "text": "ler / escrever. read, read (mesma grafia mas pron. diferente: /riːd/ → /rɛd/), write, wrote, written.", "examples": [{ "en": "I read a book yesterday.", "pt": "Li um livro ontem." }, { "en": "She writes emails every day.", "pt": "Ela escreve emails todo dia." }] }, "tags": ["verb", "irregular", "a1"] },
    { "type": "basic", "front": { "text": "to speak / to listen" }, "back": { "text": "falar / escutar. speak, spoke, spoken. listen é regular (listened). 'Listen TO' (sempre com preposição).", "examples": [{ "en": "I speak English.", "pt": "Falo inglês." }, { "en": "Listen to me carefully.", "pt": "Me escute com atenção." }] }, "tags": ["verb", "a1"] },
    { "type": "basic", "front": { "text": "to like / to love" }, "back": { "text": "gostar / amar. Ambos regulares. Estrutura: 'I like + noun' ('I like coffee'), 'I like + verb-ing' ('I like reading') ou 'I like to + verb' ('I like to read').", "examples": [{ "en": "I like chocolate.", "pt": "Gosto de chocolate." }, { "en": "She loves her dog.", "pt": "Ela ama o cachorro dela." }] }, "tags": ["verb", "regular", "a1"] },
    { "type": "basic", "front": { "text": "to need / to want" }, "back": { "text": "precisar / querer. Ambos regulares. 'Need' implica necessidade; 'want' é desejo.", "examples": [{ "en": "I need help.", "pt": "Preciso de ajuda." }, { "en": "I want a coffee.", "pt": "Quero um café." }] }, "tags": ["verb", "regular", "a1"] },
    { "type": "basic", "front": { "text": "to live" }, "back": { "text": "morar, viver — live, lived (regular). Frequentemente com 'in': live in Brazil.", "examples": [{ "en": "I live in São Paulo.", "pt": "Moro em São Paulo." }, { "en": "They lived together for 10 years.", "pt": "Eles viveram juntos por 10 anos." }] }, "tags": ["verb", "regular", "a1"] }
  ]
}
