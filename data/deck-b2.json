{
  "id": "deck-b2-builtin",
  "name": "B2 - Idioms & Advanced Vocabulary",
  "level": "b2",
  "description": "Phrasal verbs avançados, idioms, vocabulário acadêmico e estruturas complexas",
  "cards": [
    { "type": "basic", "front": { "text": "account for", "hint": "phrasal verb" }, "back": { "text": "explicar, justificar / representar (porcentagem)", "examples": [{ "en": "How do you account for the difference?", "pt": "Como você explica a diferença?" }, { "en": "Exports account for 30% of GDP.", "pt": "As exportações representam 30% do PIB." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "allow for", "hint": "phrasal verb" }, "back": { "text": "levar em conta, considerar", "examples": [{ "en": "We must allow for delays.", "pt": "Devemos levar em conta atrasos." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "back up", "hint": "phrasal verb" }, "back": { "text": "apoiar / fazer backup", "examples": [{ "en": "I'll back you up.", "pt": "Vou te apoiar." }, { "en": "Back up your files.", "pt": "Faça backup dos arquivos." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "boil down to", "hint": "phrasal verb" }, "back": { "text": "resumir-se a, reduzir-se a", "examples": [{ "en": "It all boils down to money.", "pt": "Tudo se resume a dinheiro." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "brush up on", "hint": "phrasal verb" }, "back": { "text": "revisar, dar uma repassada (em assunto que já sabia)", "examples": [{ "en": "I need to brush up on my French.", "pt": "Preciso repassar meu francês." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "call off", "hint": "phrasal verb" }, "back": { "text": "cancelar", "examples": [{ "en": "They called off the meeting.", "pt": "Cancelaram a reunião." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "come across", "hint": "phrasal verb" }, "back": { "text": "encontrar por acaso / passar a impressão", "examples": [{ "en": "I came across an old letter.", "pt": "Encontrei uma carta antiga." }, { "en": "He comes across as arrogant.", "pt": "Ele passa a impressão de arrogante." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "fall behind", "hint": "phrasal verb" }, "back": { "text": "ficar para trás, atrasar-se", "examples": [{ "en": "Don't fall behind in your studies.", "pt": "Não fique para trás nos estudos." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "follow through", "hint": "phrasal verb" }, "back": { "text": "levar até o fim, cumprir", "examples": [{ "en": "She always follows through on her promises.", "pt": "Ela sempre cumpre as promessas." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "give in", "hint": "phrasal verb" }, "back": { "text": "ceder, render-se", "examples": [{ "en": "Don't give in to pressure.", "pt": "Não ceda à pressão." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "look down on", "hint": "phrasal verb" }, "back": { "text": "menosprezar, desprezar", "examples": [{ "en": "He looks down on others.", "pt": "Ele menospreza os outros." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "make do with", "hint": "phrasal verb" }, "back": { "text": "se virar com (o que tem)", "examples": [{ "en": "We'll have to make do with what we have.", "pt": "Teremos que nos virar com o que temos." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "opt out", "hint": "phrasal verb" }, "back": { "text": "optar por não participar", "examples": [{ "en": "She opted out of the meeting.", "pt": "Ela optou por não participar da reunião." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "pull off", "hint": "phrasal verb" }, "back": { "text": "conseguir fazer (algo difícil)", "examples": [{ "en": "I can't believe she pulled it off.", "pt": "Não acredito que ela conseguiu." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "rule out", "hint": "phrasal verb" }, "back": { "text": "descartar (uma possibilidade)", "examples": [{ "en": "We can't rule out that option.", "pt": "Não podemos descartar essa opção." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "see through", "hint": "phrasal verb" }, "back": { "text": "perceber a verdade por trás (de algo/alguém)", "examples": [{ "en": "I can see through his lies.", "pt": "Eu percebo as mentiras dele." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "sort out", "hint": "phrasal verb" }, "back": { "text": "resolver, organizar", "examples": [{ "en": "We need to sort this out.", "pt": "Precisamos resolver isso." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "stand for", "hint": "phrasal verb" }, "back": { "text": "significar (sigla) / defender (valores)", "examples": [{ "en": "What does NASA stand for?", "pt": "O que NASA significa?" }, { "en": "She stands for equality.", "pt": "Ela defende a igualdade." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "take after", "hint": "phrasal verb" }, "back": { "text": "puxar a alguém (parecer-se com parente)", "examples": [{ "en": "She takes after her mother.", "pt": "Ela puxou à mãe." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "take in", "hint": "phrasal verb" }, "back": { "text": "absorver (informação) / enganar / dar abrigo", "examples": [{ "en": "It's a lot to take in.", "pt": "É muita informação para absorver." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "take on", "hint": "phrasal verb" }, "back": { "text": "assumir (responsabilidade) / desafiar / contratar", "examples": [{ "en": "She took on a new project.", "pt": "Ela assumiu um novo projeto." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "weigh up", "hint": "phrasal verb" }, "back": { "text": "ponderar, pesar (prós e contras)", "examples": [{ "en": "I need to weigh up the options.", "pt": "Preciso ponderar as opções." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "back down", "hint": "phrasal verb" }, "back": { "text": "recuar (de uma posição)", "examples": [{ "en": "He refused to back down.", "pt": "Ele se recusou a recuar." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "look into", "hint": "phrasal verb" }, "back": { "text": "investigar, analisar", "examples": [{ "en": "We'll look into the matter.", "pt": "Vamos investigar o assunto." }] }, "tags": ["phrasal-verb", "b2"] },
    { "type": "basic", "front": { "text": "go over", "hint": "phrasal verb" }, "back": { "text": "revisar, repassar", "examples": [{ "en": "Let's go over the report.", "pt": "Vamos repassar o relatório." }] }, "tags": ["phrasal-verb", "b2"] },

    { "type": "basic", "front": { "text": "piece of cake", "hint": "idiom" }, "back": { "text": "moleza, muito fácil", "examples": [{ "en": "The exam was a piece of cake.", "pt": "A prova foi moleza." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "hit the books", "hint": "idiom" }, "back": { "text": "estudar muito (lit. 'bater nos livros')", "examples": [{ "en": "I need to hit the books tonight.", "pt": "Preciso estudar muito hoje à noite." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "under the weather", "hint": "idiom" }, "back": { "text": "indisposto, meio doente", "examples": [{ "en": "I'm feeling under the weather.", "pt": "Estou meio indisposto." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "break the ice", "hint": "idiom" }, "back": { "text": "quebrar o gelo (numa conversa)", "examples": [{ "en": "She told a joke to break the ice.", "pt": "Ela contou uma piada para quebrar o gelo." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "cut to the chase", "hint": "idiom" }, "back": { "text": "ir direto ao ponto", "examples": [{ "en": "Let's cut to the chase.", "pt": "Vamos direto ao ponto." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "on the same page", "hint": "idiom" }, "back": { "text": "estar de acordo, alinhados", "examples": [{ "en": "Are we on the same page?", "pt": "Estamos alinhados?" }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "get the hang of", "hint": "idiom" }, "back": { "text": "pegar o jeito de algo", "examples": [{ "en": "I'm getting the hang of it.", "pt": "Estou pegando o jeito." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "beat around the bush", "hint": "idiom" }, "back": { "text": "enrolar, não ir direto ao ponto", "examples": [{ "en": "Stop beating around the bush.", "pt": "Pare de enrolar." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "miss the boat", "hint": "idiom" }, "back": { "text": "perder a oportunidade", "examples": [{ "en": "Don't miss the boat on this deal.", "pt": "Não perca essa oportunidade." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "ring a bell", "hint": "idiom" }, "back": { "text": "soar familiar, lembrar de algo", "examples": [{ "en": "His name rings a bell.", "pt": "O nome dele me soa familiar." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "bite the bullet", "hint": "idiom" }, "back": { "text": "enfrentar algo difícil, encarar a situação", "examples": [{ "en": "I had to bite the bullet and apologize.", "pt": "Tive que encarar e pedir desculpas." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "hit the nail on the head", "hint": "idiom" }, "back": { "text": "acertar em cheio, dar no alvo", "examples": [{ "en": "You hit the nail on the head.", "pt": "Você acertou em cheio." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "pull yourself together", "hint": "idiom" }, "back": { "text": "se controlar, se recompor", "examples": [{ "en": "Pull yourself together!", "pt": "Se controle!" }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "see eye to eye", "hint": "idiom" }, "back": { "text": "concordar (com alguém)", "examples": [{ "en": "We don't see eye to eye on this.", "pt": "Não concordamos sobre isso." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "speak of the devil", "hint": "idiom" }, "back": { "text": "falando no diabo (quando alguém aparece sendo mencionada)", "examples": [{ "en": "Speak of the devil — there she is!", "pt": "Falando nela, lá vem!" }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "cost an arm and a leg", "hint": "idiom" }, "back": { "text": "custar caríssimo, custar os olhos da cara", "examples": [{ "en": "This car cost me an arm and a leg.", "pt": "Este carro me custou caríssimo." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "the last straw", "hint": "idiom" }, "back": { "text": "a gota d'água", "examples": [{ "en": "That was the last straw.", "pt": "Foi a gota d'água." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "once in a blue moon", "hint": "idiom" }, "back": { "text": "raramente, uma vez na vida", "examples": [{ "en": "I see her once in a blue moon.", "pt": "Vejo ela raríssimamente." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "get cold feet", "hint": "idiom" }, "back": { "text": "amarelar, perder a coragem", "examples": [{ "en": "He got cold feet before the wedding.", "pt": "Ele amarelou antes do casamento." }] }, "tags": ["idiom", "b2"] },
    { "type": "basic", "front": { "text": "the ball is in your court", "hint": "idiom" }, "back": { "text": "a decisão é sua, é com você", "examples": [{ "en": "I've done my part — the ball is in your court.", "pt": "Fiz minha parte — agora é com você." }] }, "tags": ["idiom", "b2"] },

    { "type": "basic", "front": { "text": "pervasive" }, "back": { "text": "penetrante, generalizado, difundido", "examples": [{ "en": "There's a pervasive sense of unease.", "pt": "Há uma sensação difundida de inquietação." }] }, "tags": ["adj", "academic", "b2"] },
    { "type": "basic", "front": { "text": "prevalent" }, "back": { "text": "predominante, comum", "examples": [{ "en": "The disease is prevalent in tropical regions.", "pt": "A doença é comum em regiões tropicais." }] }, "tags": ["adj", "academic", "b2"] },
    { "type": "basic", "front": { "text": "undermine" }, "back": { "text": "minar, enfraquecer (gradualmente)", "examples": [{ "en": "These comments undermine her authority.", "pt": "Esses comentários minam a autoridade dela." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "convey" }, "back": { "text": "transmitir (ideia, mensagem)", "examples": [{ "en": "Words can't convey how I feel.", "pt": "Palavras não conseguem transmitir como me sinto." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "acknowledge" }, "back": { "text": "reconhecer, admitir", "examples": [{ "en": "She acknowledged her mistake.", "pt": "Ela reconheceu o erro." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "scrutinize" }, "back": { "text": "examinar minuciosamente", "examples": [{ "en": "Every document was scrutinized.", "pt": "Cada documento foi examinado minuciosamente." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "advocate", "hint": "verbo ou substantivo" }, "back": { "text": "defender (uma causa) / defensor", "examples": [{ "en": "She advocates for animal rights.", "pt": "Ela defende os direitos dos animais." }] }, "tags": ["verb", "noun", "academic", "b2"] },
    { "type": "basic", "front": { "text": "contemplate" }, "back": { "text": "contemplar, ponderar", "examples": [{ "en": "He contemplated quitting his job.", "pt": "Ele ponderou pedir demissão." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "deteriorate" }, "back": { "text": "deteriorar, piorar", "examples": [{ "en": "Her health deteriorated rapidly.", "pt": "A saúde dela deteriorou rapidamente." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "anticipate" }, "back": { "text": "antecipar, prever", "examples": [{ "en": "We didn't anticipate the delay.", "pt": "Não previmos o atraso." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "jeopardize" }, "back": { "text": "colocar em risco, comprometer", "examples": [{ "en": "Don't jeopardize your career.", "pt": "Não coloque sua carreira em risco." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "exacerbate" }, "back": { "text": "agravar, piorar (uma situação)", "examples": [{ "en": "Stress can exacerbate the problem.", "pt": "O estresse pode agravar o problema." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "mitigate" }, "back": { "text": "mitigar, atenuar", "examples": [{ "en": "We need to mitigate the risks.", "pt": "Precisamos mitigar os riscos." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "alleviate" }, "back": { "text": "aliviar (dor, sofrimento)", "examples": [{ "en": "The medicine alleviates pain.", "pt": "O remédio alivia a dor." }] }, "tags": ["verb", "academic", "b2"] },
    { "type": "basic", "front": { "text": "endorse" }, "back": { "text": "endossar, apoiar publicamente", "examples": [{ "en": "The politician endorsed the bill.", "pt": "O político apoiou o projeto." }] }, "tags": ["verb", "academic", "b2"] },

    { "type": "cloze", "front": { "hint": "third conditional" }, "cloze": { "sentence": "If I had known, I [would have come] earlier.", "blank": "would have come" }, "back": { "text": "Third conditional: if + past perfect, ... would have + particípio (situações hipotéticas do passado)" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "wish + past perfect" }, "cloze": { "sentence": "I wish I [had studied] harder.", "blank": "had studied" }, "back": { "text": "'wish + past perfect' = arrependimento sobre o passado" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "subjunctive" }, "cloze": { "sentence": "I suggested that he [be] more careful.", "blank": "be" }, "back": { "text": "Subjuntivo após 'suggest, recommend, insist, demand': use a forma base do verbo (be, go, do — sem 's' na 3ª pessoa)" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "inversion after negative" }, "cloze": { "sentence": "Never [have I seen] such a beautiful sunset.", "blank": "have I seen" }, "back": { "text": "Inversão após advérbio negativo: Never have I... / Rarely does she... (uso formal/literário)" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "causative have" }, "cloze": { "sentence": "I [had my hair cut] yesterday.", "blank": "had my hair cut" }, "back": { "text": "Causativo: 'have + object + past participle' = mandar fazer algo (eu não cortei, alguém cortou para mim)" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "modal of deduction" }, "cloze": { "sentence": "She [must have left] already — her car is gone.", "blank": "must have left" }, "back": { "text": "'must have + particípio' = dedução sobre o passado (deve ter feito X, conclusão lógica)" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "by the time" }, "cloze": { "sentence": "By the time we arrived, the movie [had started].", "blank": "had started" }, "back": { "text": "Past perfect (had + particípio) para ações que aconteceram ANTES de outra no passado" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "future perfect" }, "cloze": { "sentence": "By next year, I [will have finished] my degree.", "blank": "will have finished" }, "back": { "text": "Future perfect: will have + particípio (ação que estará completa antes de um ponto no futuro)" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "should have" }, "cloze": { "sentence": "You [should have told] me earlier.", "blank": "should have told" }, "back": { "text": "'should have + particípio' = crítica/arrependimento sobre o passado (você deveria ter feito X)" }, "tags": ["grammar", "b2"] },
    { "type": "cloze", "front": { "hint": "as if / as though" }, "cloze": { "sentence": "He talks [as if] he knew everything.", "blank": "as if" }, "back": { "text": "'as if/as though + past subjunctive' = como se (situação contrária à realidade)" }, "tags": ["grammar", "b2"] },

    { "type": "listening", "front": { "text": "I would have called you if I had had your number.", "audioText": "I would have called you if I had had your number." }, "back": { "text": "Eu teria te ligado se tivesse seu número." }, "tags": ["listening", "phrase", "b2"] },
    { "type": "listening", "front": { "text": "She seems to have forgotten our meeting.", "audioText": "She seems to have forgotten our meeting." }, "back": { "text": "Ela parece ter esquecido nossa reunião." }, "tags": ["listening", "phrase", "b2"] }
  ]
}
