    { "type": "basic", "front": { "text": "How are you?" }, "back": { "text": "Como vai você?", "examples": [{ "en": "Hi, how are you?", "pt": "Oi, como você está?" }] }, "tags": ["phrase", "a1"] },
    { "type": "basic", "front": { "text": "Nice to meet you." }, "back": { "text": "Prazer em conhecê-lo.", "examples": [{ "en": "I'm John. Nice to meet you.", "pt": "Sou o João. Prazer." }] }, "tags": ["phrase", "a1"] },
