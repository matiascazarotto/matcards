    { "type": "cloze", "front": { "hint": "verb 'to be', presente" }, "cloze": { "sentence": "She [is] my sister.", "blank": "is" }, "back": { "text": "presente de 'to be': I am, you are, he/she/it is, we/you/they are" }, "tags": ["grammar", "a1"] },
    { "type": "cloze", "front": { "hint": "verb 'to be', passado" }, "cloze": { "sentence": "We [were] at the park yesterday.", "blank": "were" }, "back": { "text": "passado de 'to be': I/he/she/it was, you/we/they were" }, "tags": ["grammar", "a1"] },
    { "type": "cloze", "front": { "hint": "presente simples, 3ª pessoa" }, "cloze": { "sentence": "He [works] at a hospital.", "blank": "works" }, "back": { "text": "3ª pessoa do singular no presente simples leva 's': he works, she runs, it eats" }, "tags": ["grammar", "a1"] },
    { "type": "cloze", "front": { "hint": "passado simples de 'go'" }, "cloze": { "sentence": "I [went] to Paris last summer.", "blank": "went" }, "back": { "text": "passado simples de 'go' é 'went' (irregular)" }, "tags": ["grammar", "a1"] },
    { "type": "cloze", "front": { "hint": "artigo apropriado" }, "cloze": { "sentence": "I have [an] apple.", "blank": "an" }, "back": { "text": "Usa-se 'an' antes de palavras começando com som de vogal: an apple, an hour, an idea" }, "tags": ["grammar", "a1"] },
    { "type": "cloze", "front": { "hint": "plural" }, "cloze": { "sentence": "There are three [children] in the room.", "blank": "children" }, "back": { "text": "Plural irregular: child → children, foot → feet, man → men, woman → women" }, "tags": ["grammar", "a2"] },
    { "type": "cloze", "front": { "hint": "preposição de tempo" }, "cloze": { "sentence": "I'll see you [on] Monday.", "blank": "on" }, "back": { "text": "Use 'on' com dias específicos: on Monday, on June 5th. 'in' com meses/anos, 'at' com horas." }, "tags": ["grammar", "a2"] },
    { "type": "cloze", "front": { "hint": "modal de habilidade" }, "cloze": { "sentence": "She [can] speak three languages.", "blank": "can" }, "back": { "text": "'can' = poder/conseguir (habilidade). Negativa: cannot/can't" }, "tags": ["grammar", "a2"] },
    { "type": "cloze", "front": { "hint": "there is/there are" }, "cloze": { "sentence": "[There] are many books on the table.", "blank": "There" }, "back": { "text": "'There is/are' = existe/existem. Use 'is' com singular, 'are' com plural" }, "tags": ["grammar", "a2"] },
    { "type": "cloze", "front": { "hint": "comparativo" }, "cloze": { "sentence": "This box is [bigger] than that one.", "blank": "bigger" }, "back": { "text": "Comparativo de adjetivos curtos: adicione '-er'. Big → bigger (duplica consoante), happy → happier" }, "tags": ["grammar", "a2"] }
  ]
