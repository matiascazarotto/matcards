    { "type": "basic", "front": { "text": "tired" }, "back": { "text": "cansado", "examples": [{ "en": "I'm so tired.", "pt": "Estou tão cansado." }] }, "tags": ["adj", "a2"] },
    { "type": "basic", "front": { "text": "beautiful" }, "back": { "text": "bonito, lindo", "examples": [{ "en": "What a beautiful view!", "pt": "Que vista linda!" }] }, "tags": ["adj", "a2"] },
